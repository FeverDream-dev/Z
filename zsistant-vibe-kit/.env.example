# Zsistant Secret Keys Reference
#
# This file documents ALL supported secret keys for ~/.zazi/config.yaml.
# Copy the keys you need into your config — do NOT commit real values.
#
# Quick setup via CLI:
#   ./zazi init                        # creates ~/.zazi/config.yaml
#   Then edit the file or use the web UI Settings modal.
#
# Quick setup via web:
#   ./zazi serve → http://localhost:8080 → Settings (gear icon)

# =============================================================================
# LLM Providers
# =============================================================================

# Ollama Cloud — streaming supported
secrets:
  ollama_api_key: ""

  # OpenAI-compatible (works with any OpenAI API mirror)
  openai_api_key: ""
  openai_base_url: "https://api.openai.com/v1"

  # Z.AI Coding Plan — specialized coding provider
  zai_api_key: ""

  # OpenCode Zen — opencode.ai provider
  opencode_api_key: ""

  # =============================================================================
  # Additional providers (cataloged but not yet wired)
  # Add keys for any of the 48 cataloged providers to activate them:
  #
  # anthropic_api_key: ""
  # google_api_key: ""
  # mistral_api_key: ""
  # cohere_api_key: ""
  # groq_api_key: ""
  # together_api_key: ""
  # fireworks_api_key: ""
  # deepseek_api_key: ""
  # perplexity_api_key: ""
  # huggingface_api_key: ""
  # replicate_api_key: ""
  # ai21_api_key: ""
  # aleph_alpha_api_key: ""
  # stability_api_key: ""
  # =============================================================================

  # =============================================================================
  # Channel Adapters
  # =============================================================================

  # Telegram — one token per agent
  # Format: telegram_<agent-id>_token
  telegram_my-agent_token: ""

  # Discord — one token per agent
  # Format: discord_<agent-id>_token
  discord_my-agent_token: ""

  # WhatsApp — per-agent config
  # Format: whatsapp_<agent-id>_<field>
  whatsapp_my-agent_access_token: ""
  whatsapp_my-agent_phone_id: ""
  whatsapp_my-agent_verify_token: ""

# =============================================================================
# General Config (non-secret)
# =============================================================================

data_path: ~/.zazi
log_level: info        # debug | info | warn | error
server_port: 8080
